[user]
  name = John Tobin
  email = johntobin@johntobin.ie
[color]
  diff = auto
  status = auto
  branch = auto
[core]
  excludesfile = ~/.gitignore.global
[alias]
  upstream = commit -a -m 'Upstream changes.'
  unpushed-commits = log @{u}..
  unpushed-commits-diffs = diff @{u}..
[push]
  default = current
  followTags = true
[diff]
  colorMoved = true
  colorMovedWS = allow-indentation-change
  noprefix = true
  tool = nvimdiff
[pull]
  rebase = false
[difftool]
	prompt = false
[difftool "nvimdiff"]
  cmd = nvim -d "$LOCAL" "$REMOTE"
